# SonarCloud API token — generate at https://sonarcloud.io/account/security
SONAR_TOKEN=your_sonarcloud_token_here

# Optional defaults — can be overridden per tool call
SONAR_DEFAULT_ORG=your_organisation_slug
SONAR_DEFAULT_PROJECT=your_project_key

# Logging level for the sonar_mcp package (DEBUG, INFO, WARNING, ERROR). Default: WARNING
# LOG_LEVEL=DEBUG
